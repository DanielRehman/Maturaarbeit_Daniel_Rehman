      svgBarChart(title, rows, options = {}) {
        const showXLabels = options.showXLabels !== false;
        const width = options.dynamicWidth && !showXLabels
          ? Math.max(980, 145 + rows.length * 7)
          : 980;
        const height = 560, left = 115, right = 30, top = 65, bottom = showXLabels ? 170 : 95;
        const values = rows.map(r => Number(r.value)).filter(Number.isFinite);
        let minValue = options.diverging ? Math.min(-5, ...values) : (options.min ?? 0);
        let maxValue = options.diverging ? Math.max(5, ...values) : (options.max ?? Math.max(1, ...values));
        if (options.diverging && values.length) {
          const span = Math.max(1, maxValue - minValue);
          minValue -= span * 0.08;
          maxValue += span * 0.08;
        }
        const plotW = width - left - right, plotH = height - top - bottom;
        const scaleY = v => top + (maxValue - v) / (maxValue - minValue) * plotH;
        const zeroY = scaleY(0);
        const barW = options.dynamicWidth && !showXLabels
          ? Math.max(3, Math.min(6, plotW / Math.max(1, rows.length) * 0.72))
          : Math.max(4, plotW / Math.max(1, rows.length) * 0.72);
        const step = plotW / Math.max(1, rows.length);
        const bars = rows.map((r, i) => {
          const x = left + i * step + (step - barW) / 2;
          const y = Math.min(scaleY(Number(r.value)), zeroY);
          const h = Math.abs(scaleY(Number(r.value)) - zeroY);
          const fill = r.color || (Number(r.value) >= 0 ? '#15803d' : '#dc2626');
          const rawValueY = Number(r.value) >= 0 ? y - 8 : y + h + 18;
          const valueY = Math.max(top + 14, Math.min(top + plotH - 4, rawValueY));
          return [
            `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${barW.toFixed(1)}" height="${Math.max(1, h).toFixed(1)}" fill="${fill}" opacity="0.78"/>`,
            options.showValues ? `<text x="${(x + barW / 2).toFixed(1)}" y="${valueY.toFixed(1)}" text-anchor="middle" font-size="16" font-weight="700" fill="#0f172a">${this.xmlEscape(this.num(r.value, options.valueDigits ?? 0))}</text>` : '',
          ].join('\n');
        }).join('\n');
        const tickCount = 4;
        const ticks = options.gridLines ? Array.from({ length: tickCount + 1 }, (_, i) => {
          const value = minValue + (maxValue - minValue) * i / tickCount;
          const y = scaleY(value);
          return [
            `<line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#e2e8f0"/>`,
            `<text x="${left - 10}" y="${(y + 5).toFixed(1)}" text-anchor="end" font-size="16" fill="#64748b">${Number(value).toFixed(0)}</text>`,
          ].join('\n');
        }).join('\n') : '';
        const labels = !showXLabels ? '' : rows.map((r, i) => {
          const x = left + i * step + step / 2;
          const y = top + plotH + 24;
          return `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" transform="rotate(-45 ${x.toFixed(1)} ${y.toFixed(1)})" font-size="20" text-anchor="end" fill="#475569">${this.xmlEscape(this.shorten(r.label, 18))}</text>`;
        }).join('\n');
        return this.svgWrap(width, height, title, [
          `<text x="${width / 2}" y="34" text-anchor="middle" font-size="26" font-weight="700" fill="#0f172a">${this.xmlEscape(title)}</text>`,
          `<text x="28" y="${top + plotH / 2}" transform="rotate(-90 28 ${top + plotH / 2})" text-anchor="middle" font-size="24" fill="#475569">${this.xmlEscape(options.yLabel || '')}</text>`,
          options.xLabel ? `<text x="${left + plotW / 2}" y="${height - 24}" text-anchor="middle" font-size="24" fill="#475569">${this.xmlEscape(options.xLabel)}</text>` : '',
          `<line x1="${left}" y1="${zeroY.toFixed(1)}" x2="${width - right}" y2="${zeroY.toFixed(1)}" stroke="#94a3b8" stroke-dasharray="4 4"/>`,
          `<line x1="${left}" y1="${top}" x2="${left}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          `<line x1="${left}" y1="${top + plotH}" x2="${width - right}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          ticks,
          bars,
          labels,
        ].join('\n'));
      },

      svgGroupedBarChart(title, rows, options = {}) {
        const width = 980, height = 585, left = 115, right = 30, top = 72, bottom = options.legendPosition === 'bottom' ? 205 : 170;
        const maxValue = options.max ?? Math.max(1, ...rows.flatMap(r => [Number(r.a), Number(r.b)]));
        const minValue = options.min ?? 0;
        const plotW = width - left - right, plotH = height - top - bottom;
        const scaleY = v => top + (maxValue - v) / (maxValue - minValue) * plotH;
        const step = plotW / Math.max(1, rows.length);
        const barW = Math.max(3, step * 0.28);
        const bars = rows.map((r, i) => {
          const cx = left + i * step + step / 2;
          const ya = scaleY(Number(r.a)), yb = scaleY(Number(r.b));
          return [
            `<rect x="${(cx - barW - 1).toFixed(1)}" y="${ya.toFixed(1)}" width="${barW.toFixed(1)}" height="${(top + plotH - ya).toFixed(1)}" fill="#64748b" opacity="0.78"/>`,
            `<rect x="${(cx + 1).toFixed(1)}" y="${yb.toFixed(1)}" width="${barW.toFixed(1)}" height="${(top + plotH - yb).toFixed(1)}" fill="#2563eb" opacity="0.78"/>`,
            options.showValues ? `<text x="${(cx - barW / 2 - 1).toFixed(1)}" y="${(ya - 7).toFixed(1)}" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">${this.num(r.a, options.valueDigits ?? 0)}</text>` : '',
            options.showValues ? `<text x="${(cx + barW / 2 + 1).toFixed(1)}" y="${(yb - 7).toFixed(1)}" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">${this.num(r.b, options.valueDigits ?? 0)}</text>` : '',
          ].join('\n');
        }).join('\n');
        const tickCount = 4;
        const ticks = options.gridLines ? Array.from({ length: tickCount + 1 }, (_, i) => {
          const value = minValue + (maxValue - minValue) * i / tickCount;
          const y = scaleY(value);
          return [
            `<line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#e2e8f0"/>`,
            `<text x="${left - 10}" y="${(y + 5).toFixed(1)}" text-anchor="end" font-size="16" fill="#64748b">${Number(value).toFixed(0)}</text>`,
          ].join('\n');
        }).join('\n') : '';
        const labels = rows.map((r, i) => {
          const x = left + i * step + step / 2;
          const y = top + plotH + 24;
          return `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" transform="rotate(-45 ${x.toFixed(1)} ${y.toFixed(1)})" font-size="20" text-anchor="end" fill="#475569">${this.xmlEscape(this.shorten(r.label, 18))}</text>`;
        }).join('\n');
        const legend = options.legendPosition === 'bottom'
          ? [
              `<rect x="${left + plotW / 2 - 95}" y="${height - 42}" width="18" height="18" fill="#64748b" opacity="0.78"/><text x="${left + plotW / 2 - 70}" y="${height - 27}" font-size="18" fill="#475569">${this.xmlEscape(options.aLabel || 'A')}</text>`,
              `<rect x="${left + plotW / 2 + 20}" y="${height - 42}" width="18" height="18" fill="#2563eb" opacity="0.78"/><text x="${left + plotW / 2 + 45}" y="${height - 27}" font-size="18" fill="#475569">${this.xmlEscape(options.bLabel || 'B')}</text>`,
            ].join('\n')
          : [
              `<rect x="${width - 315}" y="18" width="18" height="18" fill="#64748b" opacity="0.78"/><text x="${width - 290}" y="33" font-size="20" fill="#475569">${this.xmlEscape(options.aLabel || 'A')}</text>`,
              `<rect x="${width - 190}" y="18" width="18" height="18" fill="#2563eb" opacity="0.78"/><text x="${width - 165}" y="33" font-size="20" fill="#475569">${this.xmlEscape(options.bLabel || 'B')}</text>`,
            ].join('\n');
        return this.svgWrap(width, height, title, [
          `<text x="${width / 2}" y="34" text-anchor="middle" font-size="26" font-weight="700" fill="#0f172a">${this.xmlEscape(title)}</text>`,
          legend,
          `<text x="28" y="${top + plotH / 2}" transform="rotate(-90 28 ${top + plotH / 2})" text-anchor="middle" font-size="24" fill="#475569">${this.xmlEscape(options.yLabel || '')}</text>`,
          `<line x1="${left}" y1="${top + plotH}" x2="${width - right}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          `<line x1="${left}" y1="${top}" x2="${left}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          ticks,
          bars,
          labels,
        ].join('\n'));
      },

      svgStackedBarChart(title, rows, options = {}) {
        const width = 980, height = 580, left = 115, right = 35, top = 88, bottom = 175;
        const totals = rows.map(r => Number(r.a || 0) + Number(r.b || 0) + Number(r.c || 0));
        const maxValue = Math.max(1, ...totals);
        const plotW = width - left - right, plotH = height - top - bottom;
        const scaleY = v => top + (maxValue - v) / maxValue * plotH;
        const step = plotW / Math.max(1, rows.length);
        const barW = Math.max(8, step * 0.54);
        const colors = ['#dc2626', '#f59e0b', '#16a34a'];
        const bars = rows.map((r, i) => {
          const x = left + i * step + (step - barW) / 2;
          let y = top + plotH;
          const parts = [
            { value: Number(r.a || 0), color: colors[0] },
            { value: Number(r.b || 0), color: colors[1] },
            { value: Number(r.c || 0), color: colors[2] },
          ];
          const rects = parts.map(part => {
            const h = part.value / maxValue * plotH;
            y -= h;
            return h <= 0 ? '' : `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${barW.toFixed(1)}" height="${Math.max(1, h).toFixed(1)}" fill="${part.color}" opacity="0.82"/>`;
          }).join('\n');
          const total = parts.reduce((sum, part) => sum + part.value, 0);
          return [
            rects,
            `<text x="${(x + barW / 2).toFixed(1)}" y="${(scaleY(total) - 7).toFixed(1)}" text-anchor="middle" font-size="13" fill="#475569">${total}</text>`,
          ].join('\n');
        }).join('\n');
        const tickCount = 4;
        const ticks = Array.from({ length: tickCount + 1 }, (_, i) => {
          const value = maxValue * i / tickCount;
          const y = scaleY(value);
          return [
            `<line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#e2e8f0"/>`,
            `<text x="${left - 10}" y="${(y + 5).toFixed(1)}" text-anchor="end" font-size="16" fill="#64748b">${Number(value).toFixed(0)}</text>`,
          ].join('\n');
        }).join('\n');
        const labels = rows.map((r, i) => {
          const x = left + i * step + step / 2;
          const y = top + plotH + 24;
          return `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" transform="rotate(-45 ${x.toFixed(1)} ${y.toFixed(1)})" font-size="20" text-anchor="end" fill="#475569">${this.xmlEscape(this.shorten(r.label, 18))}</text>`;
        }).join('\n');
        const legendX = width - 560;
        const legend = [
          { label: options.aLabel || 'A', color: colors[0], x: legendX },
          { label: options.bLabel || 'B', color: colors[1], x: legendX + 170 },
          { label: options.cLabel || 'C', color: colors[2], x: legendX + 350 },
        ].map(item =>
          `<rect x="${item.x}" y="54" width="18" height="18" fill="${item.color}" opacity="0.82"/><text x="${item.x + 25}" y="69" font-size="18" fill="#475569">${this.xmlEscape(item.label)}</text>`
        ).join('\n');
        return this.svgWrap(width, height, title, [
          `<text x="${width / 2}" y="34" text-anchor="middle" font-size="26" font-weight="700" fill="#0f172a">${this.xmlEscape(title)}</text>`,
          legend,
          `<text x="28" y="${top + plotH / 2}" transform="rotate(-90 28 ${top + plotH / 2})" text-anchor="middle" font-size="24" fill="#475569">${this.xmlEscape(options.yLabel || '')}</text>`,
          `<line x1="${left}" y1="${top + plotH}" x2="${width - right}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          `<line x1="${left}" y1="${top}" x2="${left}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          ticks,
          bars,
          labels,
        ].join('\n'));
      },

      svgDataQualityChart(title, rows) {
        return this.svgMultiStackedBarChart(title, rows.map(r => ({
          label: r.criteriaName,
          parts: [
            { label: 'Ausgewählt', value: Number(r.selectedPairs || 0), color: '#16a34a' },
            { label: 'Ausgelassen', value: Number(r.ceilingSkippedPairs || 0), color: '#0f766e' },
            { label: 'Review', value: Number(r.reviewPairs || 0), color: '#f59e0b' },
            { label: 'Manuell ausgeschlossen', value: Number(r.skippedPairs || 0), color: '#64748b' },
            { label: 'Fehler', value: Number(r.errorPairs || 0), color: '#dc2626' },
            { label: 'Unvollständig', value: Number(r.uncompletePairs || 0), color: '#2563eb' },
          ],
        })), { yLabel: 'Paare' });
      },

      svgMultiStackedBarChart(title, rows, options = {}) {
        const width = 1120, height = 620, left = 120, right = 40, top = 96, bottom = 190;
        const totals = rows.map(row => row.parts.reduce((sum, part) => sum + Number(part.value || 0), 0));
        const maxValue = Math.max(1, ...totals);
        const plotW = width - left - right, plotH = height - top - bottom;
        const scaleY = v => top + (maxValue - v) / maxValue * plotH;
        const step = plotW / Math.max(1, rows.length);
        const barW = Math.max(8, step * 0.58);
        const bars = rows.map((row, i) => {
          const x = left + i * step + (step - barW) / 2;
          let y = top + plotH;
          const rects = row.parts.map(part => {
            const value = Number(part.value || 0);
            const h = value / maxValue * plotH;
            y -= h;
            return h <= 0 ? '' : `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${barW.toFixed(1)}" height="${Math.max(1, h).toFixed(1)}" fill="${part.color}" opacity="0.84"/>`;
          }).join('\n');
          const total = row.parts.reduce((sum, part) => sum + Number(part.value || 0), 0);
          return [
            rects,
            `<text x="${(x + barW / 2).toFixed(1)}" y="${(scaleY(total) - 7).toFixed(1)}" text-anchor="middle" font-size="13" fill="#475569">${total}</text>`,
          ].join('\n');
        }).join('\n');
        const tickCount = 4;
        const ticks = Array.from({ length: tickCount + 1 }, (_, i) => {
          const value = maxValue * i / tickCount;
          const y = scaleY(value);
          return [
            `<line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#e2e8f0"/>`,
            `<text x="${left - 10}" y="${(y + 5).toFixed(1)}" text-anchor="end" font-size="16" fill="#64748b">${Number(value).toFixed(0)}</text>`,
          ].join('\n');
        }).join('\n');
        const labels = rows.map((row, i) => {
          const x = left + i * step + step / 2;
          const y = top + plotH + 24;
          return `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" transform="rotate(-45 ${x.toFixed(1)} ${y.toFixed(1)})" font-size="20" text-anchor="end" fill="#475569">${this.xmlEscape(this.shorten(row.label, 18))}</text>`;
        }).join('\n');
        const legendParts = rows[0]?.parts || [];
        const legend = legendParts.map((part, index) => {
          const x = 150 + (index % 3) * 300;
          const y = 52 + Math.floor(index / 3) * 26;
          return `<rect x="${x}" y="${y}" width="18" height="18" fill="${part.color}" opacity="0.84"/><text x="${x + 25}" y="${y + 15}" font-size="17" fill="#475569">${this.xmlEscape(part.label)}</text>`;
        }).join('\n');
        return this.svgWrap(width, height, title, [
          `<text x="${width / 2}" y="34" text-anchor="middle" font-size="26" font-weight="700" fill="#0f172a">${this.xmlEscape(title)}</text>`,
          legend,
          `<text x="28" y="${top + plotH / 2}" transform="rotate(-90 28 ${top + plotH / 2})" text-anchor="middle" font-size="24" fill="#475569">${this.xmlEscape(options.yLabel || '')}</text>`,
          `<line x1="${left}" y1="${top + plotH}" x2="${width - right}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          `<line x1="${left}" y1="${top}" x2="${left}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          ticks,
          bars,
          labels,
        ].join('\n'));
      },

      svgHistogram(title, values, binCount, options = {}) {
        const bins = options.separateZero
          ? this.histogramBinsWithZero(values, binCount)
          : this.histogramBins(values, binCount);
        return this.svgBarChart(title, bins.map(b => ({
          label: b.label,
          value: b.count,
          color: b.color || (b.center < 0 ? '#dc2626' : b.center > 0 ? '#15803d' : '#64748b'),
        })), { yLabel: 'Anzahl Paare', min: 0, showValues: true, gridLines: true });
      },

      histogramBinsWithZero(values, binCount) {
        const finite = values.map(Number).filter(Number.isFinite);
        if (!finite.length) return [{ label: 'keine Daten', center: 0, count: 0, color: '#64748b' }];
        const epsilon = 1e-9;
        const negative = finite.filter(v => v < -epsilon);
        const zero = finite.filter(v => Math.abs(v) <= epsilon);
        const positive = finite.filter(v => v > epsilon);
        const sideBins = Math.max(1, Math.floor((binCount - 1) / 2));
        const buildSide = (sideValues, count, negativeSide) => {
          if (!sideValues.length) return [];
          const min = negativeSide ? Math.min(...sideValues) : 0;
          const max = negativeSide ? 0 : Math.max(...sideValues);
          if (min === max) {
            return [{
              label: min.toFixed(0),
              center: min,
              count: sideValues.length,
              color: negativeSide ? '#dc2626' : '#15803d',
            }];
          }
          const width = (max - min) / count;
          return Array.from({ length: count }, (_, i) => {
            const low = min + i * width;
            const high = i === count - 1 ? max : low + width;
            const bucketCount = sideValues.filter(v => i === count - 1 ? v >= low && v <= high : v >= low && v < high).length;
            return {
              label: `${low.toFixed(0)} bis ${high.toFixed(0)}`,
              center: (low + high) / 2,
              count: bucketCount,
              color: negativeSide ? '#dc2626' : '#15803d',
            };
          });
        };
        return [
          ...buildSide(negative, sideBins, true),
          { label: '0', center: 0, count: zero.length, color: '#64748b' },
          ...buildSide(positive, sideBins, false),
        ];
      },

      svgScatter(title, points) {
        const width = 760, height = 600, left = 100, right = 35, top = 65, bottom = 95;
        const plotW = width - left - right, plotH = height - top - bottom;
        const sx = v => left + Number(v) / 100 * plotW;
        const sy = v => top + (100 - Number(v)) / 100 * plotH;
        const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
        const validPoints = points.filter(p => Number.isFinite(p.x) && Number.isFinite(p.y));
        const groups = new Map();
        for (const p of validPoints) {
          const key = `${Number(p.x).toFixed(2)}|${Number(p.y).toFixed(2)}`;
          if (!groups.has(key)) groups.set(key, []);
          groups.get(key).push(p);
        }
        const goldenAngle = Math.PI * (3 - Math.sqrt(5));
        const circles = [...groups.values()].flatMap(group => {
          const baseX = sx(group[0].x);
          const baseY = sy(group[0].y);
          return group.map((p, index) => {
            const spread = group.length === 1 ? 0 : Math.min(22, 2.4 * Math.sqrt(index));
            const angle = index * goldenAngle;
            const x = clamp(baseX + Math.cos(angle) * spread, left + 4, width - right - 4);
            const y = clamp(baseY + Math.sin(angle) * spread, top + 4, top + plotH - 4);
            return `<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="3" fill="#2563eb" opacity="0.48"/>`;
          });
        }).join('\n');
        const labels = [...groups.values()].filter(group => group.length > 1).map(group => {
          const x = clamp(sx(group[0].x), left + 14, width - right - 14);
          const y = clamp(sy(group[0].y) - 10, top + 14, top + plotH - 14);
          return `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">${group.length}</text>`;
        }).join('\n');
        const ticks = [0, 25, 50, 75, 100].map(value => [
          `<line x1="${sx(value).toFixed(1)}" y1="${top}" x2="${sx(value).toFixed(1)}" y2="${(top + plotH).toFixed(1)}" stroke="#e2e8f0"/>`,
          `<line x1="${left}" y1="${sy(value).toFixed(1)}" x2="${(width - right).toFixed(1)}" y2="${sy(value).toFixed(1)}" stroke="#e2e8f0"/>`,
          `<text x="${sx(value).toFixed(1)}" y="${(top + plotH + 24).toFixed(1)}" text-anchor="middle" font-size="16" fill="#64748b">${value}</text>`,
          `<text x="${(left - 10).toFixed(1)}" y="${(sy(value) + 5).toFixed(1)}" text-anchor="end" font-size="16" fill="#64748b">${value}</text>`,
        ].join('\n')).join('\n');
        return this.svgWrap(width, height, title, [
          `<text x="${width / 2}" y="34" text-anchor="middle" font-size="26" font-weight="700" fill="#0f172a">${this.xmlEscape(title)}</text>`,
          ticks,
          `<line x1="${left}" y1="${top + plotH}" x2="${width - right}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          `<line x1="${left}" y1="${top}" x2="${left}" y2="${top + plotH}" stroke="#cbd5e1"/>`,
          `<line x1="${sx(0)}" y1="${sy(0)}" x2="${sx(100)}" y2="${sy(100)}" stroke="#94a3b8" stroke-dasharray="5 5"/>`,
          circles,
          labels,
          `<text x="${width - right}" y="${top - 18}" text-anchor="end" font-size="15" fill="#64748b">n=${validPoints.length}; gleiche Scores leicht versetzt</text>`,
          `<text x="${left + plotW / 2}" y="${height - 26}" text-anchor="middle" font-size="26" fill="#475569">Score des direkten Aufrufs (%)</text>`,
          `<text x="28" y="${top + plotH / 2}" transform="rotate(-90 28 ${top + plotH / 2})" text-anchor="middle" font-size="26" fill="#475569">Score Workflow (%)</text>`,
        ].join('\n'));
      },

      svgWrap(width, height, title, content) {
        return `<svg xmlns="http://www.w3.org/2000/svg" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}" role="img" aria-label="${this.xmlEscape(title)}">
<rect width="100%" height="100%" fill="white"/>
${content}
</svg>
`;
      },

      slug(value) {
        return String(value || 'item')
          .toLowerCase()
          .replace(/ä/g, 'ae')
          .replace(/ö/g, 'oe')
          .replace(/ü/g, 'ue')
          .replace(/ß/g, 'ss')
          .replace(/[^a-z0-9_-]+/g, '_')
          .replace(/^_+|_+$/g, '')
          .slice(0, 60) || 'item';
      },

      latexEscape(value) {
        return String(value ?? '').replace(/[&%$#_{}~^\\]/g, ch => ({
          '&': '\\&', '%': '\\%', '$': '\\$', '#': '\\#', '_': '\\_', '{': '\\{', '}': '\\}', '~': '\\textasciitilde{}', '^': '\\textasciicircum{}', '\\': '\\textbackslash{}',
        }[ch]));
      },

      xmlEscape(value) {
        return String(value ?? '').replace(/[<>&"]/g, ch => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[ch]));
      },

      num(value, digits = 2) {
        return value === null || value === undefined || !Number.isFinite(Number(value)) ? 'k.A.' : Number(value).toFixed(digits);
      },

      signedNum(value, digits = 2) {
        if (value === null || value === undefined || !Number.isFinite(Number(value))) return 'k.A.';
        const n = Number(value);
        return (n >= 0 ? '+' : '') + n.toFixed(digits);
      },

      mean(values) {
        const clean = values.filter(v => Number.isFinite(v));
        if (!clean.length) return null;
        return clean.reduce((a, b) => a + b, 0) / clean.length;
      },

      median(values) {
        const clean = values.filter(v => Number.isFinite(v)).sort((a, b) => a - b);
        if (!clean.length) return null;
        const mid = Math.floor(clean.length / 2);
        return clean.length % 2 ? clean[mid] : (clean[mid - 1] + clean[mid]) / 2;
      },

      sampleSd(values) {
        const clean = values.filter(v => Number.isFinite(v));
        if (clean.length < 2) return null;
        const avg = this.mean(clean);
        return Math.sqrt(clean.reduce((sum, v) => sum + (v - avg) ** 2, 0) / (clean.length - 1));
      },

      tCritical95(df) {
        const table = { 1: 12.706, 2: 4.303, 3: 3.182, 4: 2.776, 5: 2.571, 6: 2.447, 7: 2.365, 8: 2.306, 9: 2.262, 10: 2.228, 11: 2.201, 12: 2.179, 13: 2.160, 14: 2.145, 15: 2.131, 16: 2.120, 17: 2.110, 18: 2.101, 19: 2.093, 20: 2.086, 21: 2.080, 22: 2.074, 23: 2.069, 24: 2.064, 25: 2.060, 26: 2.056, 27: 2.052, 28: 2.048, 29: 2.045, 30: 2.042 };
        if (df <= 30) return table[df] || 12.706;
        if (df <= 60) return 2.000;
        if (df <= 120) return 1.980;
        return 1.960;
      },

      studentTCdf(t, df) {
        const x = df / (df + t * t);
        const ib = this.regularizedBeta(x, df / 2, 0.5);
        return t >= 0 ? 1 - 0.5 * ib : 0.5 * ib;
      },

      regularizedBeta(x, a, b) {
        if (x <= 0) return 0;
        if (x >= 1) return 1;
        const bt = Math.exp(this.logGamma(a + b) - this.logGamma(a) - this.logGamma(b) + a * Math.log(x) + b * Math.log(1 - x));
        if (x < (a + 1) / (a + b + 2)) return bt * this.betaContinuedFraction(x, a, b) / a;
        return 1 - bt * this.betaContinuedFraction(1 - x, b, a) / b;
      },

      betaContinuedFraction(x, a, b) {
        const maxIter = 100;
        const eps = 3e-7;
        const fpmin = 1e-30;
        let qab = a + b;
        let qap = a + 1;
        let qam = a - 1;
        let c = 1;
        let d = 1 - qab * x / qap;
        if (Math.abs(d) < fpmin) d = fpmin;
        d = 1 / d;
        let h = d;
        for (let m = 1; m <= maxIter; m++) {
          const m2 = 2 * m;
          let aa = m * (b - m) * x / ((qam + m2) * (a + m2));
          d = 1 + aa * d;
          if (Math.abs(d) < fpmin) d = fpmin;
          c = 1 + aa / c;
          if (Math.abs(c) < fpmin) c = fpmin;
          d = 1 / d;
          h *= d * c;
          aa = -(a + m) * (qab + m) * x / ((a + m2) * (qap + m2));
          d = 1 + aa * d;
          if (Math.abs(d) < fpmin) d = fpmin;
          c = 1 + aa / c;
          if (Math.abs(c) < fpmin) c = fpmin;
          d = 1 / d;
          const del = d * c;
          h *= del;
          if (Math.abs(del - 1) < eps) break;
        }
        return h;
      },

      logGamma(z) {
        const p = [676.5203681218851, -1259.1392167224028, 771.3234287776531, -176.6150291621406, 12.507343278686905, -0.13857109526572012, 9.984369578019572e-6, 1.5056327351493116e-7];
        if (z < 0.5) return Math.log(Math.PI) - Math.log(Math.sin(Math.PI * z)) - this.logGamma(1 - z);
        z -= 1;
        let x = 0.9999999999998099;
        for (let i = 0; i < p.length; i++) x += p[i] / (z + i + 1);
        const t = z + p.length - 0.5;
        return 0.5 * Math.log(2 * Math.PI) + (z + 0.5) * Math.log(t) - t + Math.log(x);
      },

      formatPercent(value) {
        return value === null || value === undefined || !Number.isFinite(Number(value)) ? '-' : Number(value).toFixed(1) + '%';
      },

      formatSignedPercent(value) {
        if (value === null || value === undefined || !Number.isFinite(Number(value))) return '-';
        const n = Number(value);
        return (n >= 0 ? '+' : '') + n.toFixed(1) + '%';
      },

      formatNumber(value) {
        return value === null || value === undefined || !Number.isFinite(Number(value)) ? '-' : Number(value).toFixed(2);
      },

      formatOneDecimal(value) {
        return value === null || value === undefined || !Number.isFinite(Number(value)) ? '-' : Number(value).toFixed(1);
      },

      formatP(value) {
        if (value === null || value === undefined || !Number.isFinite(Number(value))) return '-';
        return value < 0.0001 ? '<0.0001' : value.toFixed(4);
      },

      shorten(text, length) {
        if (!text) return '';
        return text.length > length ? text.slice(0, length) + '...' : text;
      },
    };
  }
</script>

