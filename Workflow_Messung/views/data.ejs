<%- include('partials/header', {title, activePage}) %>

<div x-data="dataPage()" x-init="init()">
  <div class="flex flex-col gap-1 mb-5">
    <h1 class="text-xl font-semibold text-slate-900 dark:text-slate-100">Datenauswertung</h1>
    <p class="text-sm text-slate-500 dark:text-slate-400">Auswertung für die Diplomarbeit: ausgewählte Fragensets und Run-Sets, ein Kriterium oder alle Kriterien, gepaarter Vergleich von direktem Aufruf und Workflow.</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-[320px_1fr] gap-6">
    <aside class="space-y-4">
      <section class="border border-slate-200 dark:border-slate-700 rounded-lg bg-slate-50 dark:bg-slate-800 p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-200">Auswahl</h2>
          <div class="flex items-center gap-2">
            <button @click="selectOutputLastDefaults()" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">selectDefault</button>
            <button @click="selectAll(); markSelectionChanged()" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">Alle Daten</button>
          </div>
        </div>

        <div class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Kriterium</label>
            <select x-model="filters.criteriaId"
                    @change="reloadOptionsForCriteria()"
                    class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
              <option value="">Alle Kriterien</option>
              <template x-for="c in options.criteria" :key="c.id">
                <option :value="c.id" x-text="c.name_de"></option>
              </template>
            </select>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-xs font-medium text-slate-500 dark:text-slate-400">Fragensets</label>
              <div class="flex items-center gap-2">
                <span class="text-xs text-slate-400" x-text="filters.testsets.length + '/' + options.testsets.length"></span>
                <button @click="filters.testsets = []; markSelectionChanged()" class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">leeren</button>
                <button @click="filters.testsets = options.testsets.map(t => t.id); markSelectionChanged()" class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">alle</button>
              </div>
            </div>
            <div class="space-y-1 max-h-36 overflow-y-auto pr-1">
              <template x-for="t in options.testsets" :key="t.id">
                <label class="flex items-center justify-between gap-2 text-sm px-2 py-1.5 rounded hover:bg-white dark:hover:bg-slate-700 cursor-pointer">
                  <span class="flex items-center gap-2 min-w-0">
                    <input type="checkbox" :value="t.id" x-model="filters.testsets" @change="markSelectionChanged()" class="rounded border-slate-300">
                    <span class="truncate text-slate-700 dark:text-slate-200" x-text="t.name || '(empty)'"></span>
                  </span>
                  <span class="text-[11px] text-slate-400 whitespace-nowrap"
                        x-text="optionCountLabel(t, true)"></span>
                </label>
              </template>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-xs font-medium text-slate-500 dark:text-slate-400">Run-Sets</label>
              <div class="flex items-center gap-2">
                <span class="text-xs text-slate-400" x-text="filters.runSetIds.length + '/' + options.runSets.length"></span>
                <button @click="filters.runSetIds = []; markSelectionChanged()" class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">leeren</button>
                <button @click="filters.runSetIds = options.runSets.map(rs => rs.id); markSelectionChanged()" class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">alle</button>
              </div>
            </div>
            <div class="space-y-1 max-h-36 overflow-y-auto pr-1">
              <template x-for="rs in options.runSets" :key="rs.id">
                <label class="flex items-center justify-between gap-2 text-sm px-2 py-1.5 rounded hover:bg-white dark:hover:bg-slate-700 cursor-pointer">
                  <span class="flex items-center gap-2 min-w-0">
                    <input type="checkbox" :value="rs.id" x-model="filters.runSetIds" @change="markSelectionChanged()" class="rounded border-slate-300">
                    <span class="truncate text-slate-700 dark:text-slate-200" x-text="rs.name || rs.id"></span>
                  </span>
                  <span class="text-[11px] text-slate-400 whitespace-nowrap"
                        x-text="optionCountLabel(rs, false)"></span>
                </label>
              </template>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-xs font-medium text-slate-500 dark:text-slate-400">Workflow-Setups</label>
              <button @click="filters.workflowSetupIds = workflowOptions().map(s => s.id); markSelectionChanged()" class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">alle wählen</button>
            </div>
            <div class="space-y-1 max-h-40 overflow-y-auto pr-1">
              <template x-for="s in workflowOptions()" :key="s.id">
                <label class="flex items-center justify-between gap-2 text-sm px-2 py-1.5 rounded hover:bg-white dark:hover:bg-slate-700 cursor-pointer">
                  <span class="flex items-center gap-2 min-w-0">
                    <input type="checkbox" :value="s.id" x-model="filters.workflowSetupIds" @change="markSelectionChanged()" class="rounded border-slate-300">
                    <span class="truncate text-slate-700 dark:text-slate-200" x-text="s.name"></span>
                  </span>
                  <span class="text-xs text-slate-400" x-text="s.run_count || 0"></span>
                </label>
              </template>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-xs font-medium text-slate-500 dark:text-slate-400">Modelle</label>
              <button @click="filters.modelIds = options.models.map(m => String(m.id)); markSelectionChanged()" class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300">alle wählen</button>
            </div>
            <div class="space-y-1 max-h-32 overflow-y-auto pr-1">
              <template x-for="m in options.models" :key="m.id">
                <label class="flex items-center justify-between gap-2 text-sm px-2 py-1.5 rounded hover:bg-white dark:hover:bg-slate-700 cursor-pointer">
                  <span class="flex items-center gap-2 min-w-0">
                    <input type="checkbox" :value="String(m.id)" x-model="filters.modelIds" @change="markSelectionChanged()" class="rounded border-slate-300">
                    <span class="truncate text-slate-700 dark:text-slate-200" x-text="m.label"></span>
                  </span>
                  <span class="text-xs text-slate-400" x-text="m.run_count || 0"></span>
                </label>
              </template>
            </div>
          </div>

          <div class="space-y-2 border-t border-slate-200 dark:border-slate-700 pt-3">
            <label class="block text-sm text-slate-700 dark:text-slate-200">
              <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Max Paare pro Kriterium</span>
              <input type="number"
                     min="1"
                     step="1"
                     x-model="filters.maxPairsPerCriteria"
                     @input="markSelectionChanged()"
                     placeholder="leer = alle"
                     class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
              <span class="block text-xs text-slate-400 dark:text-slate-500 mt-1">Optional: begrenzt die tatsächlich verwendeten gültigen Paare je Kriterium, z.B. 100.</span>
            </label>
            <label class="block text-sm text-slate-700 dark:text-slate-200">
              <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Skip Paare pro Kriterium</span>
              <input type="number"
                     min="0"
                     step="1"
                     x-model="filters.skipPairsPerCriteria"
                     @input="markSelectionChanged()"
                     placeholder="0"
                     class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
              <span class="block text-xs text-slate-400 dark:text-slate-500 mt-1">Optional: überspringt zuerst N ausgewählte Paare je Kriterium. Beispiel: Max 100 + Skip 100 = zweite 100.</span>
            </label>
            <div class="block text-sm text-slate-700 dark:text-slate-200">
              <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Direkt-Score behalten (%)</span>
              <div class="grid grid-cols-2 gap-2">
                <label>
                  <span class="sr-only">Von</span>
                  <input type="number"
                         min="0"
                         max="100"
                         step="1"
                         x-model="filters.skipCeilingSingleScore"
                         @input="markSelectionChanged()"
                         placeholder="von"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
                <label>
                  <span class="sr-only">Bis</span>
                  <input type="number"
                         min="0"
                         max="100"
                         step="1"
                         x-model="filters.skipCeilingSingleScoreMax"
                         @input="markSelectionChanged()"
                         placeholder="bis"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
              </div>
              <span class="block text-xs text-slate-400 dark:text-slate-500 mt-1">Optional: behält nur Paare innerhalb des Bereichs. Beispiel: Von 20 bis 80 lässt <=20 und >=80 weg. Leer = nichts auslassen.</span>
            </div>
            <label class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-200 cursor-pointer">
              <input type="checkbox" x-model="filters.includeReview" @change="markSelectionChanged()" class="mt-0.5 rounded border-slate-300">
              <span>
                Review-Antworten einschließen
                <span class="block text-xs text-slate-400 dark:text-slate-500">Standard: Antworten mit Review-Markierung werden ausgeschlossen.</span>
              </span>
            </label>
            <label class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-200 cursor-pointer">
              <input type="checkbox" x-model="filters.includeExcluded" @change="markSelectionChanged()" class="mt-0.5 rounded border-slate-300">
              <span>
                Manuell ausgeschlossene einschließen
                <span class="block text-xs text-slate-400 dark:text-slate-500">Standard: manuell ausgeschlossene Antworten werden weggelassen.</span>
              </span>
            </label>
          </div>

          <button @click="loadAnalysis()"
                  :disabled="loading"
                  class="w-full py-2 px-4 bg-blue-600 hover:bg-blue-700 disabled:bg-slate-300 dark:disabled:bg-slate-600 text-white text-sm font-medium rounded transition-colors flex items-center justify-center gap-2">
            <svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span x-text="loading ? 'Lädt...' : 'Analyse aktualisieren'"></span>
          </button>
        </div>
      </section>

      <section class="border border-slate-200 dark:border-slate-700 rounded-lg p-4">
        <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-200 mb-2">Datenbereinigung</h2>
        <ul class="text-xs text-slate-500 dark:text-slate-400 space-y-1">
          <li>Es werden nur abgeschlossene Antworten mit Score verwendet.</li>
          <li>Fehlende Scores, Fehler und unfertige Antworten werden ausgeschlossen.</li>
          <li>Review-Markierungen und manuell ausgeschlossene Antworten werden standardmäßig ausgeschlossen.</li>
          <li>Optional kann ein Behalten-Bereich für den direkten Score gesetzt werden; außerhalb dieses Bereichs liegende Paare werden ausgeschlossen.</li>
          <li>Paare benötigen dieselbe Frage, dasselbe Modell, Fragenset, Run-Set und dieselbe Run-Nummer.</li>
          <li>Differenz = Workflow-Score minus Score des direkten Aufrufs.</li>
          <li>Übersprungene Batch-Einträge werden nicht als neue Antworten gespeichert; sie bedeuten, dass eine bestehende Antwort wiederverwendet wurde.</li>
        </ul>
      </section>
    </aside>

    <main class="min-w-0 space-y-5">
      <div x-show="error" class="border border-red-200 dark:border-red-700 bg-red-50 dark:bg-red-900/20 rounded-lg p-4 text-sm text-red-700 dark:text-red-300" x-text="error"></div>

      <div x-show="!analysis && loading" class="text-center py-16 text-slate-400 dark:text-slate-500 text-sm">Analyse wird geladen...</div>

      <template x-if="analysis">
        <div class="space-y-5">
          <div class="border-b border-slate-200 dark:border-slate-700">
            <nav class="flex gap-1 -mb-px">
              <button @click="activeDataTab = 'analysis'"
                      :class="activeDataTab === 'analysis' ? 'border-blue-600 text-blue-600 dark:text-blue-400 dark:border-blue-400' : 'border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'"
                      class="px-4 py-2 text-sm font-medium border-b-2 transition-colors">Analyse</button>
              <button @click="activeDataTab = 'overview'"
                      :class="activeDataTab === 'overview' ? 'border-blue-600 text-blue-600 dark:text-blue-400 dark:border-blue-400' : 'border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'"
                      class="px-4 py-2 text-sm font-medium border-b-2 transition-colors">Übersicht</button>
              <button @click="activeDataTab = 'ceilingCalc'"
                      :class="activeDataTab === 'ceilingCalc' ? 'border-blue-600 text-blue-600 dark:text-blue-400 dark:border-blue-400' : 'border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'"
                      class="px-4 py-2 text-sm font-medium border-b-2 transition-colors">Deckeneffekt-Rechner</button>
            </nav>
          </div>

          <div x-show="exportStatus" x-text="exportStatus"
               class="border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3 py-2 text-xs text-blue-700 dark:text-blue-300"></div>

          <section x-show="activeDataTab === 'ceilingCalc'" x-cloak class="space-y-4">
            <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3 mb-4">
                <div>
                  <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-200">Deckeneffekt-Rechner</h2>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Unabhängiger Erwartungsrechner: Wie viel Verbesserung ist sichtbar, wenn ein Teil der direkten Antworten bereits perfekt ist?</p>
                </div>
                <div class="text-xs text-slate-500 dark:text-slate-400" x-text="'Basis: ' + ceilingCalc.base + ' Fragen'"></div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-4">
                <label class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Fragen-Basis</span>
                  <input type="number" min="1" step="1" x-model.number="ceilingCalc.base"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
                <label class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Direkt: Fehler pro Basis</span>
                  <input type="number" min="0" step="0.1" x-model.number="ceilingCalc.directErrors"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
                <label class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Workflow: Fehler pro Basis</span>
                  <input type="number" min="0" step="0.1" x-model.number="ceilingCalc.workflowErrors"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
                <label class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Beispiel-Paare</span>
                  <input type="number" min="1" step="1" x-model.number="ceilingCalc.pairs"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
                <label class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">100% links (%)</span>
                  <input type="number" min="0" max="100" step="1" x-model.number="ceilingCalc.ceilingSharePct"
                         class="w-full text-sm border border-slate-300 dark:border-slate-600 rounded px-2 py-1.5 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200">
                </label>
                <div class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Steigerung Deckel-Paare</span>
                  <div class="w-full text-sm border border-slate-200 dark:border-slate-700 rounded px-2 py-1.5 bg-slate-50 dark:bg-slate-800 text-slate-800 dark:text-slate-200"
                       x-text="formatSignedPercent(ceilingCalcResult().gainCeilingPct)"></div>
                </div>
                <div class="block text-sm text-slate-700 dark:text-slate-200">
                  <span class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Steigerung nicht gedeckelt</span>
                  <div class="w-full text-sm border border-slate-200 dark:border-slate-700 rounded px-2 py-1.5 bg-slate-50 dark:bg-slate-800 text-slate-800 dark:text-slate-200"
                       x-text="formatSignedPercent(ceilingCalcResult().gainNonCeilingPct)"></div>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-3">
                <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4 bg-slate-50 dark:bg-slate-800">
                  <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Erwartete 100% links</p>
                  <p class="text-2xl font-semibold text-slate-900 dark:text-slate-100" x-text="formatPercent(ceilingCalcResult().ceilingSharePct)"></p>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1" x-text="ceilingCalcResult().ceilingPairs + ' von ' + ceilingCalcResult().pairs + ' Paaren'"></p>
                </div>
                <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4 bg-slate-50 dark:bg-slate-800">
                  <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Erwartete Steigerung in allen Paaren</p>
                  <p class="text-2xl font-semibold text-green-600 dark:text-green-400" x-text="formatSignedPercent(ceilingCalcResult().gainAllPct)"></p>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Workflow minus direkter Aufruf</p>
                </div>
                <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4 bg-slate-50 dark:bg-slate-800">
                  <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Steigerung nur nicht gedeckelte Paare</p>
                  <p class="text-2xl font-semibold text-blue-600 dark:text-blue-400" x-text="formatSignedPercent(ceilingCalcResult().gainNonCeilingPct)"></p>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1" x-text="ceilingCalcResult().nonCeilingPairs + ' nicht gedeckelte Paare'"></p>
                </div>
                <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4 bg-slate-50 dark:bg-slate-800">
                  <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Steigerung der restlichen Deckel-Paare</p>
                  <p class="text-2xl font-semibold text-slate-900 dark:text-slate-100" x-text="formatSignedPercent(ceilingCalcResult().gainCeilingPct)"></p>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Direkt ist dort 100%; Workflow-Fehler wirken nur nach unten.</p>
                </div>
              </div>

              <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mt-4">
                <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-slate-800 dark:text-slate-200 mb-2">Formel</h3>
                  <div class="space-y-1 text-xs text-slate-600 dark:text-slate-300 font-mono leading-relaxed">
                    <p x-text="'p_Direkt_Fehler = ' + ceilingCalc.directErrors + ' / ' + ceilingCalc.base + ' = ' + formatPercent(ceilingCalcResult().directErrorPct)"></p>
                    <p x-text="'p_Workflow_Fehler = ' + ceilingCalc.workflowErrors + ' / ' + ceilingCalc.base + ' = ' + formatPercent(ceilingCalcResult().workflowErrorPct)"></p>
                    <p x-text="'Anteil_Deckel = ' + formatPercent(ceilingCalcResult().ceilingSharePct)"></p>
                    <p x-text="'Anteil_nicht_Deckel = 100% - Anteil_Deckel = ' + formatPercent(ceilingCalcResult().nonCeilingSharePct)"></p>
                    <p x-text="'Steigerung_Deckel = Workflow_bei_Deckel - Direkt_bei_Deckel'"></p>
                    <p x-text="'= (100% - p_Workflow_Fehler) - 100% = -' + formatPercent(ceilingCalcResult().workflowErrorPct) + ' = ' + formatSignedPercent(ceilingCalcResult().gainCeilingPct)"></p>
                    <p x-text="'Steigerung_nicht_Deckel = Workflow_bei_nicht_Deckel - Direkt_bei_nicht_Deckel'"></p>
                    <p x-text="'= (100% - p_Workflow_Fehler) - 0% = ' + formatSignedPercent(ceilingCalcResult().gainNonCeilingPct)"></p>
                    <p x-text="'Steigerung alle = Anteil_Deckel * Steigerung_Deckel + Anteil_nicht_Deckel * Steigerung_nicht_Deckel'"></p>
